<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Colinhas.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:Colinhas.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Colinhas.Models"
    mc:Ignorable="d">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <conv:BoolToVisibilityConverter x:Key="InverseBoolToVisibility" Invert="True" />
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Search box  -->
        <AutoSuggestBox
            Grid.Row="0"
            Margin="12,8"
            HorizontalAlignment="Stretch"
            PlaceholderText="Pesquisar no histórico..."
            QueryIcon="Find"
            Text="{x:Bind ViewModel.SearchText, Mode=TwoWay}" />

        <!--  Clipboard items list  -->
        <ListView
            Grid.Row="1"
            ItemsSource="{x:Bind ViewModel.Items, Mode=OneWay}"
            SelectionMode="None">

            <ListView.ItemContainerStyle>
                <Style BasedOn="{StaticResource DefaultListViewItemStyle}" TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="12,4" />
                </Style>
            </ListView.ItemContainerStyle>

            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:ClipboardEntry">
                    <Grid
                        Padding="0,6"
                        ColumnSpacing="8"
                        RowSpacing="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!--  Pinned indicator + text preview  -->
                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="0"
                            MaxLines="2"
                            Style="{StaticResource BodyTextBlockStyle}"
                            Text="{x:Bind Display, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />

                        <!--  Timestamp + status badges  -->
                        <StackPanel
                            Grid.Row="1"
                            Grid.Column="0"
                            Orientation="Horizontal"
                            Spacing="6"
                            VerticalAlignment="Center">

                            <TextBlock
                                VerticalAlignment="Center"
                                Opacity="0.5"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Text="{x:Bind TimeLabel}" />

                            <!--  "Fixado" badge  -->
                            <Border
                                Padding="6,1"
                                VerticalAlignment="Center"
                                Background="{ThemeResource AccentFillColorDefaultBrush}"
                                CornerRadius="4"
                                Visibility="{x:Bind IsPinned, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <FontIcon
                                        FontSize="10"
                                        Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                        Glyph="&#xE718;" />
                                    <TextBlock
                                        FontSize="11"
                                        Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                        Text="Fixado" />
                                </StackPanel>
                            </Border>

                            <!--  "Oculto" badge  -->
                            <Border
                                Padding="6,1"
                                VerticalAlignment="Center"
                                Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                                CornerRadius="4"
                                Visibility="{x:Bind IsHidden, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <FontIcon
                                        FontSize="10"
                                        Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                        Glyph="&#xE7B3;" />
                                    <TextBlock
                                        FontSize="11"
                                        Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                        Text="Oculto" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!--  Action buttons  -->
                        <StackPanel
                            Grid.Row="0"
                            Grid.RowSpan="2"
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="2">

                            <!--  Copy  -->
                            <Button
                                Command="{x:Bind CopyCommand}"
                                Style="{StaticResource SubtleButtonStyle}"
                                ToolTipService.ToolTip="Copiar para área de transferência">
                                <FontIcon FontSize="14" Glyph="&#xE8C8;" />
                            </Button>

                            <!--  Hide / show content (privacy)  -->
                            <ToggleButton
                                IsChecked="{x:Bind IsHidden, Mode=TwoWay}"
                                Style="{StaticResource SubtleToggleButtonStyle}"
                                ToolTipService.ToolTip="Ocultar/mostrar conteúdo">
                                <FontIcon FontSize="14" Glyph="&#xE7B3;" />
                            </ToggleButton>

                            <!--  Pin / Unpin  -->
                            <ToggleButton
                                IsChecked="{x:Bind IsPinned, Mode=TwoWay}"
                                Style="{StaticResource SubtleToggleButtonStyle}"
                                ToolTipService.ToolTip="Fixar item">
                                <FontIcon FontSize="14" Glyph="&#xE718;" />
                            </ToggleButton>

                            <!--  Delete  -->
                            <Button
                                Command="{x:Bind DeleteCommand}"
                                Style="{StaticResource SubtleButtonStyle}"
                                ToolTipService.ToolTip="Remover do histórico">
                                <FontIcon FontSize="14" Glyph="&#xE74D;" />
                            </Button>

                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!--  Empty state (only visible when there are no items)  -->
        <StackPanel
            Grid.Row="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Spacing="8"
            Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
            <FontIcon
                HorizontalAlignment="Center"
                FontSize="40"
                Glyph="&#xE8C8;"
                Opacity="0.3" />
            <TextBlock
                HorizontalAlignment="Center"
                Opacity="0.5"
                Style="{StaticResource BodyTextBlockStyle}"
                Text="Nada copiado ainda" />
            <TextBlock
                HorizontalAlignment="Center"
                Opacity="0.4"
                Style="{StaticResource CaptionTextBlockStyle}"
                Text="Copie qualquer texto para começar" />
        </StackPanel>

        <!--  Footer  -->
        <Border
            Grid.Row="2"
            Padding="12,8"
            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0">
            <Button
                HorizontalAlignment="Right"
                Command="{x:Bind ViewModel.ClearHistoryCommand}"
                Style="{StaticResource SubtleButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon FontSize="14" Glyph="&#xE74D;" />
                    <TextBlock Text="Limpar histórico" />
                </StackPanel>
            </Button>
        </Border>

    </Grid>
</Page>
