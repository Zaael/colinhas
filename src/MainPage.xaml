<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Colinhas.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:Colinhas.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:Colinhas.Models"
    mc:Ignorable="d">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <conv:BoolToVisibilityConverter x:Key="InverseBoolToVisibility" Invert="True" />

        <Style x:Key="StretchItemStyle" BasedOn="{StaticResource DefaultListViewItemStyle}" TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="12,4" />
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Tab switcher + support button  -->
        <Grid Grid.Row="0" Margin="8,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <SelectorBar
                x:Name="ViewSelector"
                Grid.Column="0"
                SelectionChanged="ViewSelector_SelectionChanged">
                <SelectorBarItem x:Name="TabHistory" IsSelected="True" Text="Histórico" />
                <SelectorBarItem x:Name="TabTemplates" Text="Templates" />
            </SelectorBar>

            <Button
                Grid.Column="1"
                VerticalAlignment="Center"
                Click="BuyMeCoffee_Click"
                Style="{StaticResource SubtleButtonStyle}"
                ToolTipService.ToolTip="Apoie o projeto ☕">
                <TextBlock FontSize="16" Text="☕" />
            </Button>
        </Grid>

        <!--  ============ HISTÓRICO ============  -->
        <Grid x:Name="HistoryPanel" Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <AutoSuggestBox
                Grid.Row="0"
                Margin="12,4,12,8"
                HorizontalAlignment="Stretch"
                PlaceholderText="Pesquisar no histórico..."
                QueryIcon="Find"
                Text="{x:Bind ViewModel.SearchText, Mode=TwoWay}" />

            <ListView
                Grid.Row="1"
                IsItemClickEnabled="True"
                ItemClick="HistoryList_ItemClick"
                ItemContainerStyle="{StaticResource StretchItemStyle}"
                ItemsSource="{x:Bind ViewModel.FilteredItems, Mode=OneWay}"
                SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:ClipboardEntry">
                        <Grid
                            Padding="0,6"
                            ColumnSpacing="8"
                            RowSpacing="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="0"
                                MaxLines="2"
                                Style="{StaticResource BodyTextBlockStyle}"
                                Text="{x:Bind Display, Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />

                            <!--  Timestamp + status badges  -->
                            <StackPanel
                                Grid.Row="1"
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Orientation="Horizontal"
                                Spacing="6">
                                <TextBlock
                                    VerticalAlignment="Center"
                                    Opacity="0.5"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Text="{x:Bind TimeLabel}" />

                                <!--  Descrição/título do item (badge)  -->
                                <Border
                                    Padding="6,1"
                                    VerticalAlignment="Center"
                                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Visibility="{x:Bind HasLabel, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <FontIcon
                                            FontSize="10"
                                            Glyph="&#xE8EC;"
                                            Opacity="0.7" />
                                        <TextBlock FontSize="11" Text="{x:Bind Label, Mode=OneWay}" />
                                    </StackPanel>
                                </Border>

                                <Border
                                    Padding="6,1"
                                    VerticalAlignment="Center"
                                    Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                                    CornerRadius="4"
                                    Visibility="{x:Bind IsHidden, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                        <FontIcon
                                            FontSize="10"
                                            Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                            Glyph="&#xE7B3;" />
                                        <TextBlock
                                            FontSize="11"
                                            Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                            Text="Oculto" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <StackPanel
                                Grid.Row="0"
                                Grid.RowSpan="2"
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                Orientation="Horizontal"
                                Spacing="2">
                                <Button
                                    Command="{x:Bind EditLabelCommand}"
                                    Style="{StaticResource SubtleButtonStyle}"
                                    ToolTipService.ToolTip="Adicionar/editar descrição">
                                    <FontIcon FontSize="14" Glyph="&#xE8EC;" />
                                </Button>
                                <ToggleButton
                                    IsChecked="{x:Bind IsHidden, Mode=TwoWay}"
                                    Style="{StaticResource SubtleToggleButtonStyle}"
                                    ToolTipService.ToolTip="Ocultar/mostrar">
                                    <FontIcon FontSize="14" Glyph="&#xE7B3;" />
                                </ToggleButton>
                                <ToggleButton
                                    IsChecked="{x:Bind IsPinned, Mode=TwoWay}"
                                    Style="{StaticResource SubtleToggleButtonStyle}"
                                    ToolTipService.ToolTip="Fixar">
                                    <FontIcon FontSize="14" Glyph="&#xE718;" />
                                </ToggleButton>
                                <Button
                                    Command="{x:Bind DeleteCommand}"
                                    Style="{StaticResource SubtleButtonStyle}"
                                    ToolTipService.ToolTip="Remover">
                                    <FontIcon FontSize="14" Glyph="&#xE74D;" />
                                </Button>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <StackPanel
                Grid.Row="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="8"
                Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                <FontIcon
                    HorizontalAlignment="Center"
                    FontSize="40"
                    Glyph="&#xE8C8;"
                    Opacity="0.3" />
                <TextBlock
                    HorizontalAlignment="Center"
                    Opacity="0.5"
                    Style="{StaticResource BodyTextBlockStyle}"
                    Text="Nada copiado ainda" />
                <TextBlock
                    HorizontalAlignment="Center"
                    Opacity="0.4"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Text="Copie qualquer texto para começar" />
            </StackPanel>

            <!--  No search results  -->
            <StackPanel
                Grid.Row="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="8"
                Visibility="{x:Bind ViewModel.NoResults, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                <FontIcon
                    HorizontalAlignment="Center"
                    FontSize="40"
                    Glyph="&#xE721;"
                    Opacity="0.3" />
                <TextBlock
                    HorizontalAlignment="Center"
                    Opacity="0.5"
                    Style="{StaticResource BodyTextBlockStyle}"
                    Text="Nenhum resultado" />
                <TextBlock
                    HorizontalAlignment="Center"
                    Opacity="0.4"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Text="Tente outro termo de busca" />
            </StackPanel>
        </Grid>

        <!--  ============ TEMPLATES ============  -->
        <Grid
            x:Name="TemplatesPanel"
            Grid.Row="1"
            Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Button
                Grid.Row="0"
                Margin="12,4,12,8"
                HorizontalAlignment="Stretch"
                Click="AddTemplate_Click">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon FontSize="14" Glyph="&#xE710;" />
                    <TextBlock Text="Novo template" />
                </StackPanel>
            </Button>

            <ListView
                Grid.Row="1"
                ItemContainerStyle="{StaticResource StretchItemStyle}"
                ItemsSource="{x:Bind TemplatesVM.Templates, Mode=OneWay}"
                SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:TextTemplate">
                        <Grid
                            Padding="0,6"
                            ColumnSpacing="8"
                            RowSpacing="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="0"
                                Style="{StaticResource BodyStrongTextBlockStyle}"
                                Text="{x:Bind Title, Mode=OneWay}"
                                TextTrimming="CharacterEllipsis" />

                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="0"
                                MaxLines="2"
                                Opacity="0.7"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Text="{x:Bind Preview, Mode=OneWay}"
                                TextWrapping="WrapWholeWords" />

                            <!--  Badges: placeholders + atalho  -->
                            <StackPanel
                                Grid.Row="2"
                                Grid.Column="0"
                                Margin="0,4,0,0"
                                Orientation="Horizontal"
                                Spacing="6">

                                <Border
                                    Padding="7,2"
                                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Visibility="{x:Bind HasPlaceholders, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <FontIcon
                                            FontSize="10"
                                            Glyph="&#xE762;"
                                            Opacity="0.6" />
                                        <TextBlock
                                            FontSize="11"
                                            Opacity="0.8"
                                            Text="{x:Bind PlaceholderLabel, Mode=OneWay}" />
                                    </StackPanel>
                                </Border>

                                <Border
                                    Padding="7,2"
                                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Visibility="{x:Bind HasHotkey, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <FontIcon
                                            FontSize="10"
                                            Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                            Glyph="&#xE765;" />
                                        <TextBlock
                                            FontSize="11"
                                            Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                            Text="{x:Bind HotkeyLabel, Mode=OneWay}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <StackPanel
                                Grid.Row="0"
                                Grid.RowSpan="3"
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                Orientation="Horizontal"
                                Spacing="2">
                                <Button
                                    Command="{x:Bind UseCommand}"
                                    Style="{StaticResource SubtleButtonStyle}"
                                    ToolTipService.ToolTip="Usar (copiar)">
                                    <FontIcon FontSize="14" Glyph="&#xE8C8;" />
                                </Button>
                                <Button
                                    Command="{x:Bind EditCommand}"
                                    Style="{StaticResource SubtleButtonStyle}"
                                    ToolTipService.ToolTip="Editar">
                                    <FontIcon FontSize="14" Glyph="&#xE70F;" />
                                </Button>
                                <Button
                                    Command="{x:Bind DeleteCommand}"
                                    Style="{StaticResource SubtleButtonStyle}"
                                    ToolTipService.ToolTip="Excluir">
                                    <FontIcon FontSize="14" Glyph="&#xE74D;" />
                                </Button>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <StackPanel
                Grid.Row="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="8"
                Visibility="{x:Bind TemplatesVM.IsEmpty, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                <FontIcon
                    HorizontalAlignment="Center"
                    FontSize="40"
                    Glyph="&#xE8A5;"
                    Opacity="0.3" />
                <TextBlock
                    HorizontalAlignment="Center"
                    Opacity="0.5"
                    Style="{StaticResource BodyTextBlockStyle}"
                    Text="Nenhum template ainda" />
                <TextBlock
                    HorizontalAlignment="Center"
                    Opacity="0.4"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Text="Crie textos reutilizáveis com {campos}" />
            </StackPanel>
        </Grid>

        <!--  Footer (histórico)  -->
        <Border
            x:Name="HistoryFooter"
            Grid.Row="2"
            Padding="12,8"
            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0">
            <Button
                HorizontalAlignment="Right"
                Command="{x:Bind ViewModel.ClearHistoryCommand}"
                Style="{StaticResource SubtleButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon FontSize="14" Glyph="&#xE74D;" />
                    <TextBlock Text="Limpar histórico" />
                </StackPanel>
            </Button>
        </Border>

    </Grid>
</Page>
