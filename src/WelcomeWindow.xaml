<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="Colinhas.WelcomeWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Bem-vindo ao Colinhas"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.Resources>
            <!--  Um "passo" do tutorial: glifo grande, título, texto e bullets.  -->
            <Style x:Key="StepGlyphStyle" TargetType="FontIcon">
                <Setter Property="FontSize" Value="48" />
                <Setter Property="Foreground" Value="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                <Setter Property="HorizontalAlignment" Value="Left" />
            </Style>

            <Style x:Key="StepTitleStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="26" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Margin" Value="0,16,0,4" />
            </Style>

            <Style x:Key="StepBodyStyle" TargetType="TextBlock">
                <Setter Property="TextWrapping" Value="Wrap" />
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
                <Setter Property="Margin" Value="0,0,0,12" />
            </Style>

            <Style x:Key="BulletStyle" TargetType="TextBlock">
                <Setter Property="TextWrapping" Value="Wrap" />
                <Setter Property="Margin" Value="0,0,0,8" />
            </Style>

            <Style x:Key="KeyCapStyle" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource ControlFillColorDefaultBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource ControlStrokeColorDefaultBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="6" />
                <Setter Property="Padding" Value="10,4" />
                <Setter Property="HorizontalAlignment" Value="Left" />
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TitleBar x:Name="AppTitleBar" Title="Bem-vindo ao Colinhas">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="Assets/AppIcon.ico" />
            </TitleBar.IconSource>
        </TitleBar>

        <!--  ============ PASSOS ============  -->
        <Grid Grid.Row="1" Margin="40,20,40,0">

            <!--  1. O que é  -->
            <StackPanel x:Name="Step0">
                <FontIcon Glyph="&#xE8C8;" Style="{StaticResource StepGlyphStyle}" />
                <TextBlock Style="{StaticResource StepTitleStyle}" Text="Seu Ctrl+C nunca mais se perde" />
                <TextBlock Style="{StaticResource StepBodyStyle}">
                    O Colinhas guarda tudo o que você copia e devolve na hora em que precisar.
                    Ele fica na bandeja do sistema, ao lado do relógio, e some da sua frente
                    enquanto você trabalha.
                </TextBlock>

                <TextBlock Margin="0,8,0,8" Text="Para abrir, de qualquer lugar do Windows:" />
                <Border Style="{StaticResource KeyCapStyle}">
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="Ctrl + \" />
                </Border>
                <TextBlock
                    Margin="0,10,0,0"
                    Style="{StaticResource StepBodyStyle}"
                    Text="O mesmo atalho fecha. Fechar no X também só esconde — o Colinhas continua rodando." />
            </StackPanel>

            <!--  2. Histórico  -->
            <StackPanel x:Name="Step1" Visibility="Collapsed">
                <FontIcon Glyph="&#xE81C;" Style="{StaticResource StepGlyphStyle}" />
                <TextBlock Style="{StaticResource StepTitleStyle}" Text="O histórico" />
                <TextBlock Style="{StaticResource StepBodyStyle}" Text="Clique em qualquer item para usá-lo. Com &quot;colar direto&quot; ligado, ele já cola no app onde você estava — sem precisar do Ctrl+V." />

                <TextBlock Style="{StaticResource BulletStyle}"><Run FontWeight="SemiBold" Text="📌 Fixar" /><Run Text=" — o item sobe para o topo e não é descartado." /></TextBlock>
                <TextBlock Style="{StaticResource BulletStyle}"><Run FontWeight="SemiBold" Text="👁 Ocultar" /><Run Text=" — mascara o conteúdo na lista. Bom para senhas e tokens: continua colável, mas ninguém lê por cima do seu ombro." /></TextBlock>
                <TextBlock Style="{StaticResource BulletStyle}"><Run FontWeight="SemiBold" Text="🏷 Descrição" /><Run Text=" — dê um nome ao item (&quot;chave da API&quot;, &quot;meu PIX&quot;) para achar depois." /></TextBlock>
                <TextBlock Style="{StaticResource BulletStyle}"><Run FontWeight="SemiBold" Text="🔎 Busca" /><Run Text=" — filtra por conteúdo ou por descrição." /></TextBlock>
                <TextBlock
                    Margin="0,4,0,0"
                    Style="{StaticResource StepBodyStyle}"
                    Text="Tudo fica só no seu computador, criptografado com a sua conta do Windows. Nada vai para a internet." />
            </StackPanel>

            <!--  3. Templates  -->
            <StackPanel x:Name="Step2" Visibility="Collapsed">
                <FontIcon Glyph="&#xE8A5;" Style="{StaticResource StepGlyphStyle}" />
                <TextBlock Style="{StaticResource StepTitleStyle}" Text="Templates: textos que você repete" />
                <TextBlock Style="{StaticResource StepBodyStyle}" Text="Na aba Templates você guarda aquele texto que digita toda semana — e deixa os pedaços variáveis entre chaves:" />

                <Border
                    Padding="14,10"
                    Background="{ThemeResource ControlFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="6">
                    <TextBlock
                        FontFamily="Consolas"
                        TextWrapping="Wrap"
                        Text="Olá {cliente}, seu chamado {numero} foi concluído." />
                </Border>

                <TextBlock Margin="0,14,0,0" Style="{StaticResource BulletStyle}" Text="Ao usar o template, o Colinhas pergunta o valor de cada campo — e sugere o que você já digitou antes." />
                <TextBlock Style="{StaticResource BulletStyle}" Text="Cada template pode ter o seu próprio atalho de teclado global: dispare o texto sem nem abrir a janela." />
            </StackPanel>

            <!--  4. Fim + iniciar com o Windows  -->
            <StackPanel x:Name="Step3" Visibility="Collapsed">
                <FontIcon Glyph="&#xE930;" Style="{StaticResource StepGlyphStyle}" />
                <TextBlock Style="{StaticResource StepTitleStyle}" Text="Pronto para usar" />
                <TextBlock Style="{StaticResource StepBodyStyle}" Text="Procure o ícone do Colinhas na bandeja, perto do relógio. O clique direito ali abre as opções — inclusive o &quot;colar direto&quot; e este tutorial, se quiser rever." />

                <ToggleSwitch
                    x:Name="StartupSwitch"
                    Margin="0,8,0,0"
                    Header="Iniciar com o Windows"
                    OffContent="Desligado"
                    OnContent="Ligado"
                    Toggled="StartupSwitch_Toggled" />
                <TextBlock
                    x:Name="StartupHint"
                    Style="{StaticResource StepBodyStyle}"
                    Text="Recomendado: assim o histórico começa a ser guardado desde o login, sem você precisar abrir nada." />

                <TextBlock Style="{StaticResource StepBodyStyle}" Text="O Colinhas é gratuito e de código aberto. Se ele te ajudar, tem um ☕ no canto da janela principal. 💛" />
            </StackPanel>
        </Grid>

        <!--  ============ RODAPÉ ============  -->
        <Grid
            Grid.Row="2"
            Padding="40,16,40,24"
            ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!--  Indicador de progresso  -->
            <StackPanel
                Grid.Column="0"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="6">
                <Ellipse x:Name="Dot0" Width="8" Height="8" />
                <Ellipse x:Name="Dot1" Width="8" Height="8" />
                <Ellipse x:Name="Dot2" Width="8" Height="8" />
                <Ellipse x:Name="Dot3" Width="8" Height="8" />
            </StackPanel>

            <Button
                x:Name="BackButton"
                Grid.Column="2"
                MinWidth="100"
                Click="Back_Click"
                Content="Voltar"
                IsEnabled="False" />

            <Button
                x:Name="NextButton"
                Grid.Column="3"
                MinWidth="100"
                Click="Next_Click"
                Content="Próximo"
                Style="{StaticResource AccentButtonStyle}" />
        </Grid>
    </Grid>
</Window>
